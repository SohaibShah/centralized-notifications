{
  "name": "@notifications/server-fastify",
  "version": "0.0.0",
  "private": true,
  "description": "Fastify plugin mounting the notification HTTP + SSE routes onto a host server, wiring the host's auth/intakeAuth adapters to @notifications/core. Publishable-shaped; flip private -> false at the split.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@notifications/core": "workspace:*",
    "@notifications/shared": "workspace:*",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "fastify": "^5.2.1",
    "pg": "^8.22.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
