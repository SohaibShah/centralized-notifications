{
  "name": "@notifications/core",
  "version": "0.0.0",
  "private": true,
  "description": "Framework-agnostic notification domain: ingest pipeline, audience-scoped read path, delivery hub, policy/settings. Importable into any Node app with an injected pg.Pool and identity. Publishable-shaped; flip private -> false at the split.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@notifications/shared": "workspace:*",
    "pg": "^8.22.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
