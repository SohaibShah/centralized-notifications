{
  "name": "centralized-notifications",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "pnpm --filter @notifications/vue build:css",
    "dev": "concurrently -n vue-css,backend,frontend -c yellow,blue,green \"pnpm --filter @notifications/vue dev:css\" \"pnpm --filter @notifications/backend dev\" \"pnpm --filter @notifications/frontend dev\"",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @notifications/frontend test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
