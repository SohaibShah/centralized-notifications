{
  "name": "@notifications/backend",
  "version": "0.0.0",
  "private": true,
  "description": "Fastify API + (from week 5) Redis Stream consumers/workers for the notifications system.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/scripts/seed.ts",
    "sim:publish": "tsx src/scripts/sim-publish.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/secure-session": "^8.3.0",
    "@node-rs/argon2": "^2.0.2",
    "@notifications/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "pg": "^8.22.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
