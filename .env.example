# Copy this file to .env and fill in real values. Never commit .env itself.
# Env is validated at process startup (backend/src/config/env.ts) — missing/invalid
# required vars should fail fast.

# --- Database (Postgres) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
# The docker-compose dev container reads these for its bootstrap credentials, defaulting to
# `postgres` when unset. Override here (and match them in DATABASE_URL above) to use non-default
# local creds; real/deployed credentials belong in the platform's secret store, never in git.
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=postgres

# --- Auth (prototype, session-based) ---
# Secret used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=

# --- Internal intake (service-to-service module publishing) ---
# Shared secret producers send as the `x-internal-token` header on POST /internal/publish.
# Min 16 chars. Generate with: openssl rand -hex 24
INTERNAL_INTAKE_TOKEN=

# --- AI / LLM (pluggable provider; hosted Anthropic/Claude by default) ---
LLM_PROVIDER=anthropic
# A current Claude model id, e.g. claude-haiku-4-5-20251001 (fast/cheap, good for
# summarization) or claude-sonnet-5. Swappable; local Ollama is an alternative provider.
LLM_MODEL=claude-haiku-4-5-20251001
# Required when LLM_PROVIDER=anthropic. Never commit a real key.
ANTHROPIC_API_KEY=

# --- Rate limiting (per recipient / source / category; tune per environment) ---
RATE_LIMIT_PER_RECIPIENT_PER_MIN=60
RATE_LIMIT_PER_SOURCE_PER_MIN=600
RATE_LIMIT_PER_CATEGORY_PER_MIN=300

# --- Redis (added in week 5 for Redis Streams intake; unused before then) ---
# REDIS_URL=redis://localhost:6379

# --- App config ---
NODE_ENV=development
PORT=3000
